                  <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="20.0" prefWidth="867.0" text="Visuals &amp; Status Effects" textAlignment="CENTER" wrapText="true">
                     <font>
                        <Font name="Berlin Sans FB" size="33.0" />
                     </font>
                  </Label>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="• Identifiers: The Player has a Blue border; the Opponent has a Red border." wrapText="true">
                           <font><Font name="Cambria" size="25.0" /></font>
                        </Label>
                        <Label text="• Freeze: The frozen monster must skip their entire next turn." wrapText="true">
                           <font><Font name="Cambria" size="25.0" /></font>
                        </Label>
                        <Label text="• Confusion: Swaps the SCARER/LAUGHER roles of both monsters temporarily." wrapText="true">
                           <font><Font name="Cambria" size="25.0" /></font>
                        </Label>
                     </children>
                  </VBox>
                  
                  <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="20.0" prefWidth="858.0" text="Turn Sequence" textAlignment="CENTER" wrapText="true">
