                        <Font name="Berlin Sans FB" size="33.0" />
                     </font>
                  </Label>
                  <VBox spacing="8.0">
                     <children>
                        <Label text="• Shield: Blocks the next negative energy loss effect for your team." wrapText="true">
                           <font><Font name="Cambria" size="25.0" /></font>
                        </Label>
                        <Label text="• Swapper: Swaps your position with the opponent if you are behind." wrapText="true">
                           <font><Font name="Cambria" size="25.0" /></font>
                        </Label>
                        <Label text="• Energy Steal: Steals energy from the opponent." wrapText="true">
