<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.effect.BoxBlur?>
<?import javafx.scene.effect.Light.Distant?>
<?import javafx.scene.effect.Lighting?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="mainStackPane" prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="game.engine.gui.StartScreenController">
   <children>
      <ImageView fitHeight="${mainStackPane.height}" fitWidth="${mainStackPane.width}" pickOnBounds="true" preserveRatio="false">
         <image>
            <Image url="@background.png" />
         </image>
      </ImageView>

      <VBox alignment="CENTER" spacing="40.0">
         <children>
            <ImageView fitWidth="1200.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@doordashtitle.png" />
               </image>
               <effect>
                  <Lighting diffuseConstant="1.27" specularConstant="2.0" specularExponent="14.51" surfaceScale="10.0">
                     <bumpInput>
                        <BoxBlur />
                     </bumpInput>
                     <light>
                        <Light.Distant />
                     </light>
                  </Lighting>
               </effect>
               <VBox.margin>
                  <Insets bottom="50.0" />
               </VBox.margin>
            </ImageView>
            
            <VBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#onPlayButtonClicked" prefHeight="50.0" prefWidth="300.0" style="-fx-background-radius: 100px;" text="Play">
                     <font>
                        <Font name="Berlin Sans FB" size="30.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#onSettingsButtonClicked" prefHeight="50.0" prefWidth="300.0" style="-fx-background-radius: 100px;" text="Settings">
                     <font>
                        <Font name="Berlin Sans FB" size="30.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#onInstructionsButtonClicked" prefHeight="50.0" prefWidth="300.0" style="-fx-background-radius: 100px;" text="Instructions">
                     <font>
                        <Font name="Berlin Sans FB" size="30.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" onAction="#onExitButton" prefHeight="50.0" prefWidth="300.0" style="-fx-background-radius: 100px;" text="Exit">
                     <font>
                        <Font name="Berlin Sans FB" size="30.0" />
                     </font>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </children>
</StackPane>